@page "/auth/lockout"
@{
    ViewData["Title"] = "Account locked";
    Layout = "~/Pages/Shared/_AuthLayout.cshtml";
}

<div class="text-center">
    <div class="mb-4">
        <svg class="inline-block w-8 h-8 text-slate-500 dark:text-slate-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
            <path d="M7 11V7a5 5 0 0110 0v4"></path>
        </svg>
    </div>
    <h2 class="text-lg font-semibold text-slate-900 dark:text-slate-100 mb-4">Account locked</h2>
    <p class="text-sm text-slate-600 dark:text-slate-400 mb-6">
        Your account is temporarily locked after too many failed sign-in attempts. Try again in a few minutes.
    </p>
    <a href="/auth/login" class="text-indigo-600 dark:text-indigo-400 hover:underline text-sm">Back to sign in</a>
</div>
