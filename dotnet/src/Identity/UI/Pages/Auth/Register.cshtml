@page "/auth/register"
@model RegisterModel
@{
    ViewData["Title"] = "Create account";
    Layout = "~/Pages/Shared/_AuthLayout.cshtml";
}

<h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-1 text-center">Create account</h2>
<p class="text-sm text-slate-500 dark:text-slate-400 text-center mb-8">Join ELS to access your courses and workspace</p>

<form method="post" action="/auth/register" asp-antiforgery="true" class="space-y-5">
    <input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />

    <div class="space-y-1">
        <label for="fullName" class="block text-sm font-medium text-slate-700 dark:text-slate-300">Full Name</label>
        <input type="text" id="fullName" name="fullName" asp-for="FullName" autocomplete="name"
               class="w-full rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 px-4 py-3 text-sm text-slate-900 dark:text-slate-100 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-slate-900 dark:focus:ring-white focus:border-transparent transition"
               placeholder="John Doe" required />
        @{
            var fullNameErrors = ModelState.ContainsKey("FullName") ? ModelState["FullName"]?.Errors : null;
            if (fullNameErrors?.Count > 0)
            {
                <p role="alert" class="text-xs text-red-600 dark:text-red-400 mt-1">@fullNameErrors.First().ErrorMessage</p>
            }
        }
    </div>

    <div class="space-y-1">
        <label for="email" class="block text-sm font-medium text-slate-700 dark:text-slate-300">Email</label>
        <input type="email" id="email" name="email" asp-for="Email" autocomplete="email"
               class="w-full rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 px-4 py-3 text-sm text-slate-900 dark:text-slate-100 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-slate-900 dark:focus:ring-white focus:border-transparent transition"
               placeholder="you@example.com" required />
        @{
            var emailErrors = ModelState.ContainsKey("Email") ? ModelState["Email"]?.Errors : null;
            if (emailErrors?.Count > 0)
            {
                <p role="alert" class="text-xs text-red-600 dark:text-red-400 mt-1">@emailErrors.First().ErrorMessage</p>
            }
        }
    </div>

    <div class="space-y-1">
        <label for="password" class="block text-sm font-medium text-slate-700 dark:text-slate-300">Password</label>
        <div class="relative">
            <input type="password" id="password" name="password" asp-for="Password"
                   class="w-full rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 px-4 py-3 pr-11 text-sm text-slate-900 dark:text-slate-100 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-slate-900 dark:focus:ring-white focus:border-transparent transition"
                   placeholder="••••••••" required />
            <button type="button" class="togglePassword absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 hover:text-slate-700 dark:hover:text-slate-200 transition" aria-label="Toggle password visibility" data-target="password">
                <svg class="w-5 h-5 eyeIcon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                    <circle cx="12" cy="12" r="3"></circle>
                </svg>
            </button>
        </div>
        @{
            var passwordErrors = ModelState.ContainsKey("Password") ? ModelState["Password"]?.Errors : null;
            if (passwordErrors?.Count > 0)
            {
                <p role="alert" class="text-xs text-red-600 dark:text-red-400 mt-1">@passwordErrors.First().ErrorMessage</p>
            }
        }
    </div>

    <div class="space-y-1">
        <label for="confirmPassword" class="block text-sm font-medium text-slate-700 dark:text-slate-300">Confirm Password</label>
        <div class="relative">
            <input type="password" id="confirmPassword" name="confirmPassword" asp-for="ConfirmPassword"
                   class="w-full rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 px-4 py-3 pr-11 text-sm text-slate-900 dark:text-slate-100 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-slate-900 dark:focus:ring-white focus:border-transparent transition"
                   placeholder="••••••••" required />
            <button type="button" class="togglePassword absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 hover:text-slate-700 dark:hover:text-slate-200 transition" aria-label="Toggle password visibility" data-target="confirmPassword">
                <svg class="w-5 h-5 eyeIcon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                    <circle cx="12" cy="12" r="3"></circle>
                </svg>
            </button>
        </div>
        @{
            var confirmPasswordErrors = ModelState.ContainsKey("ConfirmPassword") ? ModelState["ConfirmPassword"]?.Errors : null;
            if (confirmPasswordErrors?.Count > 0)
            {
                <p role="alert" class="text-xs text-red-600 dark:text-red-400 mt-1">@confirmPasswordErrors.First().ErrorMessage</p>
            }
        }
    </div>

    <partial name="_SubmitButton" view-data="@(new ViewDataDictionary(ViewData) { { "text", "Create account" } })" />
</form>

<p class="text-sm text-center text-slate-500 dark:text-slate-400 mt-6">
    Already have an account?
    <a href="/auth/login@(!string.IsNullOrEmpty(Model.ReturnUrl) ? "?returnUrl=" + Uri.EscapeDataString(Model.ReturnUrl) : "")" class="font-medium text-slate-900 dark:text-white hover:underline">Sign in</a>
</p>

<script>
document.querySelectorAll('.togglePassword').forEach(function (btn) {
    btn.addEventListener('click', function () {
        var input = document.getElementById(this.getAttribute('data-target'));
        var icon = this.querySelector('.eyeIcon');
        if (input.type === 'password') {
            input.type = 'text';
            icon.innerHTML = '<path d="M17.94 17.94A10.07 10.07 0 003.12 3.12m14.76 14.76L3.12 3.12m14.76 14.76l1.41-1.41M1 1l22 22M9.9 4.24A9.72 9.72 0 0112 4c7 0 11 8 11 8a18.47 18.47 0 00-5.07-5.87m-6.86 6.86a3 3 0 103.34 3.34" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"></path>';
        } else {
            input.type = 'password';
            icon.innerHTML = '<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle>';
        }
    });
});
</script>
