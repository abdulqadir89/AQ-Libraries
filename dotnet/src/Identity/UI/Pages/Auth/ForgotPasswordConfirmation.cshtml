@page "/auth/forgot-password-confirmation"
@{
    ViewData["Title"] = "Forgot password";
    Layout = "~/Pages/Shared/_AuthLayout.cshtml";
}

<h2 class="text-lg font-semibold text-slate-900 dark:text-slate-100 mb-6 text-center">Check your email</h2>

<div class="bg-blue-50 dark:bg-blue-900/20 rounded-lg p-4">
    <p class="text-sm text-blue-700 dark:text-blue-400">
        If that email address is registered, you'll receive a reset link shortly. Check your inbox and spam folder.
    </p>
</div>

<a href="/auth/login" class="w-full bg-indigo-600 hover:bg-indigo-700 text-white font-medium py-2 px-4 rounded-lg transition-colors inline-block text-center mt-6">Back to sign in</a>
