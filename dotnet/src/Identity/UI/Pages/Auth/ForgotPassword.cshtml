@page "/auth/forgot-password"
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Forgot password";
    Layout = "~/Pages/Shared/_AuthLayout.cshtml";
}

<h2 class="text-lg font-semibold text-slate-900 dark:text-slate-100 mb-6 text-center">Forgot password?</h2>

<form method="post" action="/auth/forgot-password" asp-antiforgery="true" class="space-y-4">
    <p class="text-sm text-slate-600 dark:text-slate-400 mb-4">
        Enter your email address and we'll send you a link to reset your password.
    </p>

    <div>
        <label for="email" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">Email</label>
        <input type="email" id="email" name="email" asp-for="Email" autocomplete="email" class="w-full rounded-lg border border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-800 px-3 py-2 text-sm text-slate-900 dark:text-slate-100 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent" placeholder="you@example.com" required />
    </div>

    <partial name="_SubmitButton" view-data="@(new ViewDataDictionary(ViewData) { { "text", "Send reset link" } })" />
</form>

<p class="text-sm text-center text-slate-600 dark:text-slate-400 mt-6">
    Remember your password? <a href="/auth/login" class="text-indigo-600 dark:text-indigo-400 hover:underline font-medium">Sign in</a>
</p>
