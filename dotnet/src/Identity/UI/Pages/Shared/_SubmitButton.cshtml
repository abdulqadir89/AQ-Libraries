@{
    var buttonText = ViewData["text"]?.ToString() ?? "Continue";
}

<button type="submit" class="w-full bg-slate-900 hover:bg-slate-700 dark:bg-white dark:hover:bg-slate-100 dark:text-slate-900 text-white font-semibold py-3 px-4 rounded-xl transition-colors disabled:opacity-50 disabled:cursor-not-allowed flex items-center justify-center gap-2 text-sm tracking-wide" id="submitBtn">
    <span id="buttonText">@buttonText</span>
    <svg id="spinner" class="hidden w-4 h-4 animate-spin" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
    </svg>
</button>

<script>
document.addEventListener('submit', function(e) {
    var btn = document.getElementById('submitBtn');
    var spinner = document.getElementById('spinner');
    if (e.target && btn && spinner) {
        btn.disabled = true;
        spinner.classList.remove('hidden');
    }
}, true);
</script>
