@using AQ.Identity.Core.Configuration
@using Microsoft.Extensions.Options
@inject IOptions<AqIdentityOptions> options
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @options.Value.AppName</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            darkMode: 'media'
        };
    </script>
</head>
<body class="min-h-screen flex items-center justify-center bg-slate-50 dark:bg-slate-950">
    <div class="w-full max-w-sm mx-4">
        <div class="bg-white dark:bg-slate-900 rounded-2xl shadow-sm border border-slate-100 dark:border-slate-800 p-8">
            <h1 class="text-xl font-bold text-indigo-600 dark:text-indigo-400 mb-6 text-center">
                @options.Value.AppName
            </h1>

            @RenderBody()
        </div>

        <p class="text-xs text-center text-slate-400 mt-6">Powered by AQ Identity</p>
    </div>
</body>
</html>
