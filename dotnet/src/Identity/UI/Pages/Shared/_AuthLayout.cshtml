@using AQ.Identity.Core.Configuration
@using Microsoft.Extensions.Options
@inject IOptions<AqIdentityOptions> options
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @options.Value.AppName</title>
    <link rel="stylesheet" href="/_content/AQ.Identity.UI/css/identity.css" />
    <style>
        *, *::before, *::after { box-sizing: border-box; }
        body { margin: 0; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; }
        input:-webkit-autofill,
        input:-webkit-autofill:hover,
        input:-webkit-autofill:focus {
            -webkit-box-shadow: 0 0 0 1000px #fff inset;
            -webkit-text-fill-color: #0f172a;
        }
        @@media (prefers-color-scheme: dark) {
            input:-webkit-autofill,
            input:-webkit-autofill:hover,
            input:-webkit-autofill:focus {
                -webkit-box-shadow: 0 0 0 1000px #1e293b inset;
                -webkit-text-fill-color: #f1f5f9;
            }
        }
    </style>
</head>
<body class="min-h-screen bg-gradient-to-br from-slate-50 via-white to-slate-100 dark:from-slate-950 dark:via-slate-900 dark:to-slate-950 flex items-center justify-center px-4 py-8">

    <div class="w-full max-w-md">

        <!-- Logo / App name -->
        <div class="text-center mb-8">
            <span class="inline-block text-4xl font-black tracking-tight text-slate-900 dark:text-white">
                @options.Value.AppName
            </span>
        </div>

        <!-- Card -->
        <div class="bg-white dark:bg-slate-900 rounded-2xl shadow-lg shadow-slate-200/60 dark:shadow-slate-950/60 border border-slate-100 dark:border-slate-800 px-8 py-10">
            @RenderBody()
        </div>

    </div>

</body>
</html>
