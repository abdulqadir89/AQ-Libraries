@page "/auth/mfa/disable"
@model DisableModel
@{
    ViewData["Title"] = "Disable two-factor authentication";
    Layout = "~/Pages/Shared/_AuthLayout.cshtml";
}

<h2 class="text-lg font-semibold text-slate-900 dark:text-slate-100 mb-6 text-center">Disable two-factor authentication</h2>

<div class="bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 rounded-lg p-4 mb-6">
    <p class="text-sm text-amber-900 dark:text-amber-100">
        Disabling two-factor authentication makes your account less secure.
    </p>
</div>

<form method="post" asp-antiforgery="true" class="space-y-4">
    <button type="submit" class="w-full bg-red-600 hover:bg-red-700 text-white font-medium py-2 px-4 rounded-lg transition-colors disabled:opacity-50 disabled:cursor-not-allowed" id="submitBtn">
        <span id="buttonText">Disable 2FA</span>
        <svg id="spinner" class="hidden inline-block w-4 h-4 animate-spin ml-2" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
        </svg>
    </button>

    <a href="/account/security" class="block w-full border border-slate-300 dark:border-slate-600 text-slate-700 dark:text-slate-300 font-medium py-2 px-4 rounded-lg hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors text-center">
        Cancel
    </a>
</form>

<script>
document.addEventListener('submit', function(e) {
    var btn = document.getElementById('submitBtn');
    var spinner = document.getElementById('spinner');
    if (e.target && btn && spinner) {
        btn.disabled = true;
        spinner.classList.remove('hidden');
    }
}, true);
</script>
