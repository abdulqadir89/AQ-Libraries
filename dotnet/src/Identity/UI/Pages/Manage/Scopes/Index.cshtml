@page "/manage/scopes"
@model AQ.Identity.UI.Pages.Manage.Scopes.ScopesIndexModel
@{
    ViewData["Title"] = "Scopes";
    Layout = "~/Pages/Manage/_ManageLayout.cshtml";
}

<div class="space-y-6">

    <!-- Existing scopes table -->
    <div class="bg-white dark:bg-slate-900 rounded-2xl border border-slate-100 dark:border-slate-800 overflow-hidden">
        @if (Model.Scopes.Count == 0)
        {
            <div class="text-center py-16">
                <p class="text-sm text-slate-400">No scopes defined yet.</p>
            </div>
        }
        else
        {
            <table class="w-full text-sm">
                <thead>
                    <tr class="border-b border-slate-100 dark:border-slate-800">
                        <th class="text-left px-5 py-3 text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Name</th>
                        <th class="text-left px-5 py-3 text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Display Name</th>
                        <th class="text-left px-5 py-3 text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Claim Types</th>
                        <th class="px-5 py-3"></th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-50 dark:divide-slate-800">
                    @foreach (var scope in Model.Scopes)
                    {
                        <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/50 transition-colors">
                            <td class="px-5 py-3.5">
                                <div class="flex items-center gap-2">
                                    <code class="text-xs bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 px-2 py-0.5 rounded">@scope.Name</code>
                                </div>
                            </td>
                            <td class="px-5 py-3.5 text-slate-600 dark:text-slate-400">@scope.DisplayName</td>
                            <td class="px-5 py-3.5">
                                <div class="flex flex-wrap gap-1">
                                    @foreach (var ct in scope.ClaimTypes)
                                    {
                                        <span class="text-xs bg-indigo-50 dark:bg-indigo-900/30 text-indigo-700 dark:text-indigo-300 border border-indigo-100 dark:border-indigo-800 px-1.5 py-0.5 rounded font-mono">@ct</span>
                                    }
                                    @if (!scope.ClaimTypes.Any())
                                    {
                                        <span class="text-xs text-slate-400 italic">none</span>
                                    }
                                </div>
                            </td>
                            <td class="px-5 py-3.5 text-right">
                                <div class="flex items-center justify-end gap-4">
                                    <button type="button"
                                            data-scope-id="@scope.Id"
                                            data-scope-name="@scope.Name"
                                            data-display-name="@scope.DisplayName"
                                            data-description="@scope.Description"
                                            data-claim-types="@string.Join(",", scope.ClaimTypes)"
                                            onclick="openEditModal(this)"
                                            class="inline-flex items-center gap-1.5 text-xs font-medium text-indigo-600 hover:text-indigo-800 dark:text-indigo-400 dark:hover:text-indigo-300 transition-colors">
                                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                                            <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                                        </svg>
                                        Edit
                                    </button>
                                    <form method="post">
                                        <input type="hidden" name="id" value="@scope.Id" />
                                        <button type="submit" asp-page-handler="Delete"
                                                class="text-xs font-medium text-red-500 hover:text-red-700 dark:hover:text-red-400 transition-colors"
                                                onclick="return confirm('Delete scope \'@scope.Name\'?')">
                                            Delete
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>

    <!-- Add scope form -->
    <div class="bg-white dark:bg-slate-900 rounded-2xl border border-slate-100 dark:border-slate-800 p-6">
        <h2 class="text-sm font-semibold text-slate-700 dark:text-slate-300 mb-4">Add Scope</h2>

        <form method="post" class="space-y-4">

            @if (!ModelState.IsValid)
            {
                <div class="text-sm text-red-600 dark:text-red-400 bg-red-50 dark:bg-red-950/40 border border-red-200 dark:border-red-900 rounded-xl px-4 py-3">
                    @ModelState.Values.SelectMany(v => v.Errors).FirstOrDefault()?.ErrorMessage
                </div>
            }

            <div class="grid grid-cols-2 gap-4">
                <div class="space-y-1">
                    <label class="block text-sm font-medium text-slate-700 dark:text-slate-300">Name <span class="text-red-500">*</span></label>
                    <input type="text" asp-for="NewName"
                           class="w-full rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 px-3 py-2.5 text-sm font-mono text-slate-900 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition"
                           placeholder="my_scope" />
                </div>
                <div class="space-y-1">
                    <label class="block text-sm font-medium text-slate-700 dark:text-slate-300">Display Name</label>
                    <input type="text" asp-for="NewDisplayName"
                           class="w-full rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 px-3 py-2.5 text-sm text-slate-900 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition"
                           placeholder="My Scope" />
                </div>
            </div>

            <div class="space-y-1">
                <label class="block text-sm font-medium text-slate-700 dark:text-slate-300">Description</label>
                <input type="text" asp-for="NewDescription"
                       class="w-full rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 px-3 py-2.5 text-sm text-slate-900 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition"
                       placeholder="What this scope grants access to" />
            </div>

            <div class="space-y-1">
                <label class="block text-sm font-medium text-slate-700 dark:text-slate-300">Claim Types</label>
                <input type="text" asp-for="NewClaimTypesRaw"
                       class="w-full rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 px-3 py-2.5 text-sm font-mono text-slate-900 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition"
                       placeholder="claim_type_1, claim_type_2" />
                <p class="text-xs text-slate-400">Comma-separated. When this scope is granted, these claim types are included in the token from the user's stored claims.</p>
            </div>

            <div>
                <button type="submit" asp-page-handler="Create"
                        class="bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium px-5 py-2.5 rounded-xl transition-colors">
                    Add Scope
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Edit scope modal — overlay is the centering container -->
<div id="edit-modal"
     role="dialog"
     aria-modal="true"
     aria-labelledby="edit-modal-title"
     style="display:none; position:fixed; inset:0; z-index:50; align-items:center; justify-content:center;">

    <!-- Backdrop -->
    <div id="edit-backdrop"
         style="position:absolute; inset:0; background:rgba(0,0,0,0.5);"
         onclick="closeEditModal()">
    </div>

    <!-- Modal panel -->
    <div id="edit-panel"
         style="position:relative; width:100%; max-width:480px; margin:16px;"
         class="bg-white dark:bg-slate-900 shadow-2xl border border-slate-200 dark:border-slate-800 rounded-2xl flex flex-col">

        <!-- Panel header -->
        <div class="flex items-center justify-between px-6 py-5 border-b border-slate-100 dark:border-slate-800 shrink-0">
            <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-lg bg-indigo-50 dark:bg-indigo-900/40 flex items-center justify-center shrink-0">
                    <svg class="w-4 h-4 text-indigo-600 dark:text-indigo-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                    </svg>
                </div>
                <div>
                    <h2 id="edit-modal-title" class="text-sm font-semibold text-slate-900 dark:text-white">Edit Scope</h2>
                    <code id="edit-modal-name" class="text-xs text-slate-400 dark:text-slate-500 font-mono"></code>
                </div>
            </div>
            <button type="button"
                    onclick="closeEditModal()"
                    aria-label="Close"
                    class="w-8 h-8 flex items-center justify-center rounded-lg text-slate-400 hover:text-slate-700 dark:hover:text-slate-200 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
                </svg>
            </button>
        </div>

        <!-- Panel body -->
        <form method="post" id="edit-form" class="flex flex-col">
            <input type="hidden" asp-for="EditId" id="edit-id" />

            <div class="flex-1 px-6 py-6 space-y-6">

                <!-- Identity (read-only) -->
                <fieldset class="space-y-4">
                    <legend class="text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider pb-2 border-b border-slate-100 dark:border-slate-800 w-full">Identity</legend>
                    <div class="space-y-1">
                        <label class="block text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Scope Name</label>
                        <code id="edit-name-display" class="block text-sm bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 px-3 py-2.5 rounded-xl font-mono"></code>
                    </div>
                    <div class="space-y-1.5">
                        <label class="block text-sm font-medium text-slate-700 dark:text-slate-300">Display Name</label>
                        <input type="text" asp-for="EditDisplayName" id="edit-display-name"
                               class="w-full rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 px-3 py-2.5 text-sm text-slate-900 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition"
                               placeholder="My Scope" />
                    </div>
                    <div class="space-y-1.5">
                        <label class="block text-sm font-medium text-slate-700 dark:text-slate-300">Description</label>
                        <input type="text" asp-for="EditDescription" id="edit-description"
                               class="w-full rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 px-3 py-2.5 text-sm text-slate-900 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition"
                               placeholder="What this scope grants access to" />
                    </div>
                </fieldset>

                <!-- Claim types -->
                <fieldset class="space-y-4">
                    <legend class="text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider pb-2 border-b border-slate-100 dark:border-slate-800 w-full">Claim Types</legend>

                    <!-- Tag display -->
                    <div id="claim-tags" class="flex flex-wrap gap-1.5 min-h-8"></div>

                    <!-- Hidden input sent to server -->
                    <input type="hidden" asp-for="EditClaimTypesRaw" id="edit-claim-types-raw" />

                    <!-- Add claim type input -->
                    <div class="flex gap-2">
                        <input type="text" id="claim-type-input"
                               class="flex-1 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 px-3 py-2 text-sm font-mono text-slate-900 dark:text-slate-100 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition"
                               placeholder="e.g. els_system_permissions" />
                        <button type="button" onclick="addClaimTag()"
                                class="shrink-0 px-3 py-2 rounded-xl border border-slate-200 dark:border-slate-700 text-sm font-medium text-slate-600 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors">
                            Add
                        </button>
                    </div>
                    <p class="text-xs text-slate-400">Press Enter or click Add. Saving replaces all existing claim types for this scope.</p>
                </fieldset>
            </div>

            <!-- Panel footer -->
            <div class="shrink-0 px-6 py-4 border-t border-slate-100 dark:border-slate-800 bg-slate-50 dark:bg-slate-900/80 flex items-center justify-end gap-3">
                <button type="button" onclick="closeEditModal()"
                        class="text-sm font-medium text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white px-4 py-2 rounded-xl transition-colors">
                    Cancel
                </button>
                <button type="submit" formaction="?handler=Edit"
                        class="inline-flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700 active:bg-indigo-800 text-white text-sm font-medium px-5 py-2.5 rounded-xl transition-colors shadow-sm">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <polyline points="20 6 9 17 4 12"/>
                    </svg>
                    Save Changes
                </button>
            </div>
        </form>
    </div>
</div>

<style>
    #edit-panel, #edit-backdrop { transition: opacity 180ms ease; }
</style>

<script>
(function () {
    var modal = document.getElementById('edit-modal');
    var claimTags = [];

    window.openEditModal = function (btn) {
        document.getElementById('edit-id').value = btn.dataset.scopeId;
        document.getElementById('edit-modal-name').textContent = btn.dataset.scopeName;
        document.getElementById('edit-name-display').textContent = btn.dataset.scopeName;
        document.getElementById('edit-display-name').value = btn.dataset.displayName;
        document.getElementById('edit-description').value = btn.dataset.description;

        claimTags = btn.dataset.claimTypes ? btn.dataset.claimTypes.split(',').map(function (s) { return s.trim(); }).filter(Boolean) : [];
        renderTags();

        modal.style.display = 'flex';
        document.body.style.overflow = 'hidden';
        setTimeout(function () { document.getElementById('edit-display-name').focus(); }, 50);
    };

    window.closeEditModal = function () {
        modal.style.display = 'none';
        document.body.style.overflow = '';
    };

    window.addClaimTag = function () {
        var input = document.getElementById('claim-type-input');
        var val = input.value.trim();
        if (!val || claimTags.indexOf(val) !== -1) { input.value = ''; return; }
        claimTags.push(val);
        input.value = '';
        renderTags();
        input.focus();
    };

    function removeTag(val) {
        claimTags = claimTags.filter(function (t) { return t !== val; });
        renderTags();
    }

    function renderTags() {
        var container = document.getElementById('claim-tags');
        container.innerHTML = '';
        if (claimTags.length === 0) {
            container.innerHTML = '<span class="text-xs text-slate-400 italic self-center">No claim types — token will carry no extra claims for this scope.</span>';
        } else {
            claimTags.forEach(function (tag) {
                var chip = document.createElement('span');
                chip.className = 'inline-flex items-center gap-1 text-xs bg-indigo-50 dark:bg-indigo-900/40 text-indigo-700 dark:text-indigo-300 border border-indigo-100 dark:border-indigo-800 pl-2 pr-1 py-1 rounded-lg font-mono';
                chip.innerHTML =
                    tag +
                    '<button type="button" class="ml-0.5 text-indigo-400 hover:text-indigo-700 dark:hover:text-indigo-200 leading-none text-sm transition-colors" aria-label="Remove ' + tag + '">' +
                    '<svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>' +
                    '</button>';
                chip.querySelector('button').addEventListener('click', function () { removeTag(tag); });
                container.appendChild(chip);
            });
        }
        document.getElementById('edit-claim-types-raw').value = claimTags.join(',');
    }

    // Enter key in claim-type-input adds the tag
    document.getElementById('claim-type-input').addEventListener('keydown', function (e) {
        if (e.key === 'Enter') { e.preventDefault(); window.addClaimTag(); }
    });

    // Escape closes
    document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape' && modal.classList.contains('is-open')) closeEditModal();
    });
})();
</script>
