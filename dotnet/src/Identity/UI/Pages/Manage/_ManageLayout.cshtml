@using AQ.Identity.Core.Configuration
@using Microsoft.Extensions.Options
@inject IOptions<AqIdentityOptions> options
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @options.Value.AppName Admin</title>
    <link rel="stylesheet" href="/_content/AQ.Identity.UI/css/identity.css" />
    <style>
        *, *::before, *::after { box-sizing: border-box; }
        body { margin: 0; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; }
    </style>
</head>
<body class="min-h-screen bg-slate-50 dark:bg-slate-950 flex">

    <!-- Sidebar -->
    <aside class="w-56 shrink-0 min-h-screen bg-white dark:bg-slate-900 border-r border-slate-100 dark:border-slate-800 flex flex-col">
        <div class="px-5 py-5 border-b border-slate-100 dark:border-slate-800">
            <span class="text-base font-black tracking-tight text-slate-900 dark:text-white">@options.Value.AppName</span>
            <p class="text-xs text-slate-400 mt-0.5">Identity Admin</p>
        </div>

        <nav class="flex flex-col gap-1 p-3 flex-1">
            @{
                var currentPage = ViewContext.RouteData.Values["page"]?.ToString() ?? string.Empty;

                string NavClass(string prefix) =>
                    currentPage.StartsWith(prefix, StringComparison.OrdinalIgnoreCase)
                        ? "flex items-center gap-2.5 px-3 py-2 rounded-lg text-sm font-medium bg-indigo-50 dark:bg-indigo-900/30 text-indigo-700 dark:text-indigo-300"
                        : "flex items-center gap-2.5 px-3 py-2 rounded-lg text-sm font-medium text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 hover:text-slate-900 dark:hover:text-white transition-colors";
            }

            <a href="/manage/clients" class="@NavClass("/Manage/Clients")">
                <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
                    <rect x="2" y="3" width="20" height="14" rx="2" /><path d="M8 21h8M12 17v4"/>
                </svg>
                Clients
            </a>

            <a href="/manage/scopes" class="@NavClass("/Manage/Scopes")">
                <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
                    <circle cx="12" cy="12" r="3"/><path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/>
                </svg>
                Scopes
            </a>

            <a href="/manage/users" class="@NavClass("/Manage/Users")">
                <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/>
                </svg>
                Users
            </a>

            <div class="mt-auto pt-3 border-t border-slate-100 dark:border-slate-800">
                <a href="/account/profile" class="flex items-center gap-2.5 px-3 py-2 rounded-lg text-sm font-medium text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 hover:text-slate-900 dark:hover:text-white transition-colors">
                    <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
                        <circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/>
                    </svg>
                    My Account
                </a>
            </div>
        </nav>
    </aside>

    <!-- Main content -->
    <main class="flex-1 min-h-screen flex flex-col">
        <header class="bg-white dark:bg-slate-900 border-b border-slate-100 dark:border-slate-800 px-8 py-4 flex items-center justify-between">
            <h1 class="text-lg font-semibold text-slate-900 dark:text-white">@ViewData["Title"]</h1>
            @if (ViewData["Actions"] != null)
            {
                @Html.Raw(ViewData["Actions"]!.ToString())
            }
        </header>

        <div class="flex-1 p-8">
            @if (TempData["Success"] != null)
            {
                <div class="mb-6 flex items-center gap-3 bg-green-50 dark:bg-green-950/40 border border-green-200 dark:border-green-900 text-green-800 dark:text-green-300 rounded-xl px-4 py-3 text-sm">
                    <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                    @TempData["Success"]
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="mb-6 flex items-center gap-3 bg-red-50 dark:bg-red-950/40 border border-red-200 dark:border-red-900 text-red-800 dark:text-red-300 rounded-xl px-4 py-3 text-sm">
                    <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                    @TempData["Error"]
                </div>
            }

            @RenderBody()
        </div>
    </main>

</body>
</html>
