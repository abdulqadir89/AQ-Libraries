@page "/manage/users/{id}/claims"
@model AQ.Identity.UI.Pages.Manage.Users.ClaimsModel
@{
    ViewData["Title"] = "User Claims";
    Layout = "~/Pages/Manage/_ManageLayout.cshtml";
}

<!-- Header -->
<div class="mb-6 flex items-center gap-4">
    <a href="/manage/users" class="text-sm text-slate-500 hover:text-slate-800 dark:hover:text-slate-200 transition-colors">
        ← Users
    </a>
    <div>
        <h1 class="text-lg font-semibold text-slate-800 dark:text-slate-100">@Model.TargetUser.FullName</h1>
        <p class="text-sm text-slate-400">@Model.TargetUser.Email</p>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="mb-4 rounded-xl bg-green-50 dark:bg-green-900/30 border border-green-200 dark:border-green-800 px-4 py-3 text-sm text-green-700 dark:text-green-400">
        @TempData["Success"]
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="mb-4 rounded-xl bg-red-50 dark:bg-red-900/30 border border-red-200 dark:border-red-800 px-4 py-3 text-sm text-red-700 dark:text-red-400">
        @TempData["Error"]
    </div>
}

<!-- Claims Table -->
<div class="bg-white dark:bg-slate-900 rounded-2xl border border-slate-100 dark:border-slate-800 overflow-hidden mb-6">
    @if (Model.Claims.Count == 0)
    {
        <div class="text-center py-12">
            <p class="text-sm text-slate-400">No stored claims for this user.</p>
        </div>
    }
    else
    {
        <div class="px-5 py-3 border-b border-slate-100 dark:border-slate-800">
            <p class="text-xs text-slate-400">@Model.Claims.Count stored claim@(Model.Claims.Count == 1 ? "" : "s")</p>
        </div>
        <table class="w-full text-sm">
            <thead>
                <tr class="border-b border-slate-100 dark:border-slate-800">
                    <th class="text-left px-5 py-3 text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Type</th>
                    <th class="text-left px-5 py-3 text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Value</th>
                    <th class="px-5 py-3"></th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-50 dark:divide-slate-800">
                @foreach (var claim in Model.Claims)
                {
                    <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/50 transition-colors">
                        <td class="px-5 py-3.5 font-medium text-slate-800 dark:text-slate-200 font-mono text-xs">@claim.Type</td>
                        <td class="px-5 py-3.5 text-slate-500 dark:text-slate-400 text-xs font-mono">@claim.Value</td>
                        <td class="px-5 py-3.5">
                            <div class="flex justify-end">
                                <form method="post">
                                    <input type="hidden" name="claimId" value="@claim.Id" />
                                    <button type="submit" asp-page-handler="DeleteClaim"
                                            class="text-xs font-medium text-red-500 hover:text-red-700 dark:hover:text-red-400 transition-colors"
                                            onclick="return confirm('Remove claim \'@Html.Raw(claim.Type.Replace("'", "\\'"))\'?')">
                                        Remove
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

<!-- Add Claim Form -->
<div class="bg-white dark:bg-slate-900 rounded-2xl border border-slate-100 dark:border-slate-800 p-5">
    <h2 class="text-sm font-semibold text-slate-700 dark:text-slate-300 mb-4">Add Claim</h2>
    <form method="post" asp-page-handler="AddClaim" class="flex gap-3 items-end flex-wrap">
        <div class="flex flex-col gap-1">
            <label class="text-xs text-slate-500 dark:text-slate-400">Claim Type</label>
            <input type="text" name="claimType" placeholder="e.g. manage_api"
                   class="w-48 rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 px-3 py-2 text-sm text-slate-900 dark:text-slate-100 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition font-mono" />
        </div>
        <div class="flex flex-col gap-1">
            <label class="text-xs text-slate-500 dark:text-slate-400">Value</label>
            <input type="text" name="claimValue" placeholder="e.g. true"
                   class="w-40 rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 px-3 py-2 text-sm text-slate-900 dark:text-slate-100 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition font-mono" />
        </div>
        <button type="submit"
                class="text-sm font-medium bg-indigo-600 hover:bg-indigo-700 text-white px-4 py-2 rounded-xl transition-colors">
            Add Claim
        </button>
    </form>
</div>
