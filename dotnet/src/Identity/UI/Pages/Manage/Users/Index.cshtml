@page "/manage/users"
@model AQ.Identity.UI.Pages.Manage.Users.UsersIndexModel
@{
    ViewData["Title"] = "Users";
    Layout = "~/Pages/Manage/_ManageLayout.cshtml";
}

<!-- Search -->
<form method="get" class="mb-6">
    <div class="flex gap-3">
        <input type="text" name="Search" value="@Model.Search"
               class="w-64 rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 px-3 py-2 text-sm text-slate-900 dark:text-slate-100 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition"
               placeholder="Search by name or email…" />
        <button type="submit"
                class="text-sm font-medium bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 px-4 py-2 rounded-xl hover:bg-slate-200 dark:hover:bg-slate-700 transition-colors">
            Search
        </button>
        @if (!string.IsNullOrEmpty(Model.Search))
        {
            <a href="/manage/users" class="text-sm text-slate-500 hover:text-slate-800 dark:hover:text-slate-200 py-2 transition-colors">Clear</a>
        }
    </div>
</form>

<div class="bg-white dark:bg-slate-900 rounded-2xl border border-slate-100 dark:border-slate-800 overflow-hidden">
    @if (Model.Users.Count == 0)
    {
        <div class="text-center py-16">
            <p class="text-sm text-slate-400">@(string.IsNullOrEmpty(Model.Search) ? "No users found." : $"No users matching '{Model.Search}'.")</p>
        </div>
    }
    else
    {
        <div class="px-5 py-3 border-b border-slate-100 dark:border-slate-800">
            <p class="text-xs text-slate-400">@Model.Users.Count user@(Model.Users.Count == 1 ? "" : "s")</p>
        </div>
        <table class="w-full text-sm">
            <thead>
                <tr class="border-b border-slate-100 dark:border-slate-800">
                    <th class="text-left px-5 py-3 text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider">User</th>
                    <th class="text-left px-5 py-3 text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Status</th>
                    <th class="text-left px-5 py-3 text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Last Login</th>
                    <th class="text-left px-5 py-3 text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Created</th>
                    <th class="px-5 py-3"></th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-50 dark:divide-slate-800">
                @foreach (var user in Model.Users)
                {
                    <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/50 transition-colors">
                        <td class="px-5 py-3.5">
                            <div class="font-medium text-slate-800 dark:text-slate-200">@user.FullName</div>
                            <div class="text-xs text-slate-400 mt-0.5">@user.Email</div>
                        </td>
                        <td class="px-5 py-3.5">
                            @if (user.IsActive)
                            {
                                <span class="inline-flex items-center gap-1 text-xs font-medium bg-green-50 dark:bg-green-900/30 text-green-700 dark:text-green-400 border border-green-200 dark:border-green-800 px-2 py-0.5 rounded-full">
                                    <span class="w-1.5 h-1.5 rounded-full bg-green-500 dark:bg-green-400"></span>
                                    Active
                                </span>
                            }
                            else
                            {
                                <span class="inline-flex items-center gap-1 text-xs font-medium bg-slate-100 dark:bg-slate-800 text-slate-500 dark:text-slate-400 border border-slate-200 dark:border-slate-700 px-2 py-0.5 rounded-full">
                                    <span class="w-1.5 h-1.5 rounded-full bg-slate-400"></span>
                                    Inactive
                                </span>
                            }
                        </td>
                        <td class="px-5 py-3.5 text-slate-500 dark:text-slate-400 text-xs">
                            @(user.LastLoginAt.HasValue ? user.LastLoginAt.Value.ToString("MMM d, yyyy") : "Never")
                        </td>
                        <td class="px-5 py-3.5 text-slate-500 dark:text-slate-400 text-xs">
                            @user.CreatedAt.ToString("MMM d, yyyy")
                        </td>
                        <td class="px-5 py-3.5">
                            <div class="flex items-center gap-3 justify-end">
                                <form method="post">
                                    <input type="hidden" name="userId" value="@user.Id" />
                                    <button type="submit" asp-page-handler="ToggleActive"
                                            class="text-xs font-medium text-slate-500 hover:text-slate-800 dark:hover:text-slate-200 transition-colors">
                                        @(user.IsActive ? "Deactivate" : "Activate")
                                    </button>
                                </form>
                                <span class="text-slate-200 dark:text-slate-700">|</span>
                                <form method="post">
                                    <input type="hidden" name="userId" value="@user.Id" />
                                    <button type="submit" asp-page-handler="InvalidateSessions"
                                            class="text-xs font-medium text-amber-600 hover:text-amber-800 dark:hover:text-amber-400 transition-colors"
                                            onclick="return confirm('Invalidate all sessions for @Html.Raw(user.FullName.Replace("'", "\\'"))?')">
                                        Invalidate Sessions
                                    </button>
                                </form>
                                <span class="text-slate-200 dark:text-slate-700">|</span>
                                <a href="/manage/users/@user.Id/claims"
                                   class="text-xs font-medium text-indigo-600 hover:text-indigo-800 dark:hover:text-indigo-400 transition-colors">
                                    Claims
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
