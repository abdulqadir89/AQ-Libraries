@using AQ.Identity.Core.Abstractions
@using AQ.Identity.Core.Configuration
@using AQ.Identity.Core.Entities
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using Microsoft.Extensions.Options
@inject IOptions<AqIdentityOptions> options
@inject UserManager<ApplicationUser> userManager
@inject IIdentityDbContext identityDb
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @options.Value.AppName</title>
    <link rel="stylesheet" href="/_content/AQ.Identity.UI/css/identity.css" />
    <style>
        *, *::before, *::after { box-sizing: border-box; }
        body { margin: 0; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; }
    </style>
</head>
<body class="min-h-screen bg-slate-50 dark:bg-slate-950 flex">

    @{
        var currentUser = await userManager.GetUserAsync(User);
        var currentPage = ViewContext.RouteData.Values["page"]?.ToString() ?? string.Empty;
        var initials = string.IsNullOrEmpty(currentUser?.FullName)
            ? "?"
            : string.Concat(currentUser.FullName.Split(' ', StringSplitOptions.RemoveEmptyEntries).Take(2).Select(w => w[0])).ToUpper();

        var isAdmin = currentUser != null && await identityDb.StoredClaims
            .AsNoTracking()
            .AnyAsync(c => c.UserId == currentUser.Id && c.Type == "manage_api");

        string NavClass(string page) =>
            currentPage.Equals(page, StringComparison.OrdinalIgnoreCase)
                ? "flex items-center gap-2.5 px-3 py-2 rounded-lg text-sm font-medium bg-indigo-50 dark:bg-indigo-900/30 text-indigo-700 dark:text-indigo-300"
                : "flex items-center gap-2.5 px-3 py-2 rounded-lg text-sm font-medium text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 hover:text-slate-900 dark:hover:text-white transition-colors";
    }

    <!-- Sidebar -->
    <aside class="w-56 shrink-0 min-h-screen bg-white dark:bg-slate-900 border-r border-slate-100 dark:border-slate-800 flex flex-col">

        <!-- App brand -->
        <div class="px-5 py-4 border-b border-slate-100 dark:border-slate-800">
            <a href="/" class="text-base font-black tracking-tight text-slate-900 dark:text-white hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors">
                @options.Value.AppName
            </a>
        </div>

        <!-- User identity -->
        <div class="px-4 py-4 border-b border-slate-100 dark:border-slate-800">
            <div class="flex items-center gap-3">
                <div class="w-9 h-9 rounded-full bg-indigo-100 dark:bg-indigo-900/50 flex items-center justify-center shrink-0">
                    <span class="text-sm font-semibold text-indigo-700 dark:text-indigo-300">@initials</span>
                </div>
                <div class="min-w-0">
                    <p class="text-sm font-medium text-slate-900 dark:text-white truncate">@(currentUser?.FullName ?? "Account")</p>
                    <p class="text-xs text-slate-400 truncate">@(currentUser?.Email ?? "")</p>
                </div>
            </div>
        </div>

        <!-- Navigation -->
        <nav class="flex-1 p-3 space-y-0.5">
            <a href="/account" class="@NavClass("/Account/Index")">
                <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
                    <rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/>
                </svg>
                Overview
            </a>

            <a href="/account/profile" class="@NavClass("/Account/Profile")">
                <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
                    <circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/>
                </svg>
                Profile
            </a>

            <a href="/account/security" class="@NavClass("/Account/Security")">
                <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                </svg>
                Security
            </a>

            <a href="/account/sessions" class="@NavClass("/Account/Sessions")">
                <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
                    <rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/>
                </svg>
                Sessions
            </a>

            <a href="/account/apps" class="@NavClass("/Account/Apps")">
                <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
                    <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
                </svg>
                Connected Apps
            </a>
        </nav>

        @if (isAdmin)
        {
            <!-- Administration section -->
            <div class="px-3 pb-2">
                <div class="border-t border-slate-100 dark:border-slate-800 pt-3">
                    <p class="px-3 mb-1 text-xs font-semibold text-slate-400 dark:text-slate-500 uppercase tracking-wider">Administration</p>
                    <a href="/manage/clients"
                       class="flex items-center gap-2.5 px-3 py-2 rounded-lg text-sm font-medium text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 hover:text-slate-900 dark:hover:text-white transition-colors">
                        <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
                            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                            <path d="M9 12l2 2 4-4"/>
                        </svg>
                        Identity Admin
                    </a>
                </div>
            </div>
        }

        <!-- Sign out -->
        <div class="p-3 border-t border-slate-100 dark:border-slate-800">
            <form method="post" action="/auth/logout">
                <button type="submit"
                        class="w-full flex items-center gap-2.5 px-3 py-2 rounded-lg text-sm font-medium text-slate-500 dark:text-slate-400 hover:bg-red-50 dark:hover:bg-red-950/30 hover:text-red-600 dark:hover:text-red-400 transition-colors">
                    <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
                        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/>
                    </svg>
                    Sign out
                </button>
            </form>
        </div>

    </aside>

    <!-- Main content -->
    <main class="flex-1 min-h-screen">
        <div class="max-w-2xl mx-auto px-8 py-10">

            @if (TempData["AccountSuccess"] != null)
            {
                <div class="mb-6 flex items-center gap-3 bg-green-50 dark:bg-green-950/40 border border-green-200 dark:border-green-900 text-green-800 dark:text-green-300 rounded-xl px-4 py-3 text-sm">
                    <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                    @TempData["AccountSuccess"]
                </div>
            }

            @RenderBody()
        </div>
    </main>

</body>
</html>
