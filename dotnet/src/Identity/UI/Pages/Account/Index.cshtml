@page "/account"
@model AQ.Identity.UI.Pages.Account.AccountIndexModel
@{
    ViewData["Title"] = "Overview";
    Layout = "_AccountLayout";
}

<div class="space-y-6">

    <!-- Welcome header -->
    <div>
        <h1 class="text-2xl font-bold text-slate-900 dark:text-white">
            Hello, @Model.CurrentUser.FullName.Split(' ')[0]
        </h1>
        <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">
            Manage your account, security settings, and connected apps.
        </p>
    </div>

    <!-- Stats row -->
    <div class="grid grid-cols-3 gap-4">
        <div class="bg-white dark:bg-slate-900 rounded-2xl border border-slate-100 dark:border-slate-800 p-4">
            <p class="text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-1">Two-Factor Auth</p>
            @if (Model.TwoFactorEnabled)
            {
                <div class="flex items-center gap-1.5">
                    <span class="w-2 h-2 rounded-full bg-green-500 shrink-0"></span>
                    <span class="text-sm font-semibold text-green-700 dark:text-green-400">Enabled</span>
                </div>
            }
            else
            {
                <div class="flex items-center gap-1.5">
                    <span class="w-2 h-2 rounded-full bg-amber-400 shrink-0"></span>
                    <span class="text-sm font-semibold text-amber-700 dark:text-amber-400">Disabled</span>
                </div>
            }
        </div>

        <div class="bg-white dark:bg-slate-900 rounded-2xl border border-slate-100 dark:border-slate-800 p-4">
            <p class="text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-1">Active Sessions</p>
            <p class="text-2xl font-bold text-slate-900 dark:text-white">@Model.ActiveSessionCount</p>
        </div>

        <div class="bg-white dark:bg-slate-900 rounded-2xl border border-slate-100 dark:border-slate-800 p-4">
            <p class="text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-1">Connected Apps</p>
            <p class="text-2xl font-bold text-slate-900 dark:text-white">@Model.ConnectedAppCount</p>
        </div>
    </div>

    <!-- Account details card -->
    <div class="bg-white dark:bg-slate-900 rounded-2xl border border-slate-100 dark:border-slate-800 divide-y divide-slate-100 dark:divide-slate-800">
        <div class="flex items-center justify-between px-5 py-4">
            <div>
                <p class="text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-0.5">Full Name</p>
                <p class="text-sm font-medium text-slate-900 dark:text-white">@Model.CurrentUser.FullName</p>
            </div>
            <a href="/account/profile" class="text-xs font-medium text-indigo-600 dark:text-indigo-400 hover:underline">Edit</a>
        </div>

        <div class="flex items-center justify-between px-5 py-4">
            <div>
                <p class="text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-0.5">Email Address</p>
                <p class="text-sm font-medium text-slate-900 dark:text-white">@Model.CurrentUser.Email</p>
            </div>
            @if (Model.CurrentUser.EmailConfirmed)
            {
                <span class="inline-flex items-center gap-1 text-xs font-medium text-green-700 dark:text-green-400">
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
                    Verified
                </span>
            }
            else
            {
                <a href="/auth/verify-email-sent?email=@Uri.EscapeDataString(Model.CurrentUser.Email ?? "")" class="text-xs font-medium text-amber-600 dark:text-amber-400 hover:underline">Verify</a>
            }
        </div>

        <div class="flex items-center justify-between px-5 py-4">
            <div>
                <p class="text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-0.5">Password</p>
                <p class="text-sm text-slate-500 dark:text-slate-400">Last changed via security settings</p>
            </div>
            <a href="/account/security" class="text-xs font-medium text-indigo-600 dark:text-indigo-400 hover:underline">Change</a>
        </div>

        <div class="flex items-center justify-between px-5 py-4">
            <div>
                <p class="text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-0.5">Two-Factor Authentication</p>
                @if (Model.TwoFactorEnabled)
                {
                    <p class="text-sm text-slate-500 dark:text-slate-400">Authenticator app enabled</p>
                }
                else
                {
                    <p class="text-sm text-amber-600 dark:text-amber-400">Not set up — your account is less secure</p>
                }
            </div>
            @if (Model.TwoFactorEnabled)
            {
                <a href="/account/security" class="text-xs font-medium text-slate-500 dark:text-slate-400 hover:underline">Manage</a>
            }
            else
            {
                <a href="/auth/mfa/setup" class="text-xs font-medium text-indigo-600 dark:text-indigo-400 hover:underline">Set up</a>
            }
        </div>

        @if (Model.LastLoginAt.HasValue)
        {
            <div class="px-5 py-4">
                <p class="text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-0.5">Last Sign-in</p>
                <p class="text-sm text-slate-600 dark:text-slate-400">@Model.LastLoginAt.Value.ToString("dddd, d MMMM yyyy 'at' HH:mm")</p>
            </div>
        }
    </div>

    @if (!Model.TwoFactorEnabled)
    {
        <!-- Security nudge -->
        <div class="bg-amber-50 dark:bg-amber-950/30 border border-amber-200 dark:border-amber-800 rounded-2xl px-5 py-4 flex items-start gap-3">
            <svg class="w-5 h-5 text-amber-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
                <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>
            </svg>
            <div class="flex-1">
                <p class="text-sm font-semibold text-amber-800 dark:text-amber-300">Secure your account</p>
                <p class="text-xs text-amber-700 dark:text-amber-400 mt-0.5">Enable two-factor authentication to protect your account from unauthorised access.</p>
            </div>
            <a href="/auth/mfa/setup"
               class="shrink-0 text-xs font-semibold text-amber-800 dark:text-amber-300 border border-amber-300 dark:border-amber-700 px-3 py-1.5 rounded-lg hover:bg-amber-100 dark:hover:bg-amber-900/40 transition-colors">
                Enable 2FA
            </a>
        </div>
    }

    @if (Model.HasManageAccess)
    {
        <div class="bg-white dark:bg-slate-900 rounded-2xl border border-slate-100 dark:border-slate-800 px-5 py-4 flex items-center justify-between">
            <div>
                <p class="text-sm font-semibold text-slate-900 dark:text-white">Identity Administration</p>
                <p class="text-xs text-slate-500 dark:text-slate-400 mt-0.5">Manage clients, scopes, and users.</p>
            </div>
            <a href="/manage/clients"
               class="text-xs font-medium bg-indigo-600 hover:bg-indigo-700 text-white px-3 py-1.5 rounded-lg transition-colors">
                Open Admin
            </a>
        </div>
    }

</div>
