@page "/account/sessions"
@model AQ.Identity.UI.Pages.Account.SessionsModel
@{
    ViewData["Title"] = "Sessions";
    Layout = "_AccountLayout";
}

<div class="space-y-6">
    <div class="flex items-center justify-between">
        <div>
            <h2 class="text-lg font-semibold text-slate-900 dark:text-slate-100">Active Sessions</h2>
            <p class="text-sm text-slate-500 dark:text-slate-400 mt-0.5">These are your currently active access tokens across all apps.</p>
        </div>
        @if (Model.Sessions.Count > 1)
        {
            <form method="post">
                <button type="submit" asp-page-handler="RevokeAll"
                        onclick="return confirm('This will sign you out of all sessions everywhere. Continue?')"
                        class="text-sm font-medium text-red-600 dark:text-red-400 border border-red-200 dark:border-red-800 px-3 py-1.5 rounded-lg hover:bg-red-50 dark:hover:bg-red-950/30 transition-colors">
                    Revoke all
                </button>
            </form>
        }
    </div>

    @if (Model.Sessions.Count == 0)
    {
        <div class="bg-white dark:bg-slate-900 rounded-2xl border border-slate-100 dark:border-slate-800 py-16 text-center">
            <svg class="w-8 h-8 text-slate-300 dark:text-slate-700 mx-auto mb-3" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/>
            </svg>
            <p class="text-sm text-slate-400">No active sessions found.</p>
        </div>
    }
    else
    {
        <div class="bg-white dark:bg-slate-900 rounded-2xl border border-slate-100 dark:border-slate-800 divide-y divide-slate-100 dark:divide-slate-800">
            @foreach (var session in Model.Sessions)
            {
                <div class="flex items-center justify-between px-5 py-4">
                    <div class="flex items-center gap-3">
                        <div class="w-8 h-8 rounded-lg bg-slate-100 dark:bg-slate-800 flex items-center justify-center shrink-0">
                            <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
                                <rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/>
                            </svg>
                        </div>
                        <div>
                            <p class="text-sm font-medium text-slate-900 dark:text-white">@session.AppName</p>
                            <p class="text-xs text-slate-400 mt-0.5">
                                Issued @session.CreatedAt.ToString("d MMM yyyy, HH:mm")
                                @if (session.ExpiresAt.HasValue)
                                {
                                    <span> · Expires @session.ExpiresAt.Value.ToString("d MMM yyyy, HH:mm")</span>
                                }
                            </p>
                        </div>
                    </div>
                    <form method="post">
                        <input type="hidden" name="tokenId" value="@session.TokenId" />
                        <button type="submit" asp-page-handler="Revoke"
                                class="text-xs font-medium text-red-500 hover:text-red-700 dark:hover:text-red-400 transition-colors">
                            Revoke
                        </button>
                    </form>
                </div>
            }
        </div>
    }
</div>
